# Supabase (get these from https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API for AI summaries (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Resend for email delivery (https://resend.com — free tier: 3,000/mo)
RESEND_API_KEY=re_...
# Sender must be a verified domain in your Resend account
REPORT_FROM_EMAIL=nadzor@statera.mk
# Fallback recipient if project has no client_info email
REPORT_FALLBACK_EMAIL=engineer@statera.mk

# Firm details for PDF reports
NEXT_PUBLIC_FIRM_NAME="Statera Engineering"
NEXT_PUBLIC_FIRM_SUBTITLE="Техничка контрола и надзор на градежни објекти"
